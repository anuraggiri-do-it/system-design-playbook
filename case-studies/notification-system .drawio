    </mxCell>

    <!-- ═══════════════════════════════════════════
         CACHE  (user settings / device tokens)
    ═══════════════════════════════════════════ -->
    <mxCell id="cache" value="Cache (Redis)&#xa;user settings + device tokens&#xa;reduces DB hits"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="290" y="480" width="220" height="75" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════
         EDGES
    ═══════════════════════════════════════════ -->

    <!-- Services → Notification Service -->
    <mxCell id="e1" value="trigger notification"
      style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#6c8ebf;"
      edge="1" source="svc_group" target="notif_svc" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Notification Service → User Info DB -->
    <mxCell id="e2" value="fetch device token / prefs"
      style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#d6b656;"
      edge="1" source="notif_svc" target="userdb" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Notification Service → Cache -->
    <mxCell id="e3" value="check cache first"
      style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#d6b656;dashed=1;"
      edge="1" source="notif_svc" target="cache" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Notification Service → Queues -->
    <mxCell id="e4" value="enqueue by type"
      style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#82b366;"
      edge="1" source="notif_svc" target="q_group" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Queues → Workers -->
    <mxCell id="e5" value="pull"
      style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#82b366;"
      edge="1" source="q_group" target="w_group" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Workers → Third-Party Providers -->
    <mxCell id="e6" value="send via API"
      style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#9673a6;"
      edge="1" source="w_group" target="tp_group" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Third-Party Providers → Devices -->
    <mxCell id="e7" value="deliver"
      style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#6c8ebf;"
      edge="1" source="tp_group" target="dev_group" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Workers → Notification Log DB (persist + retry) -->
    <mxCell id="e8" value="log + retry on fail"
      style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#b85450;dashed=1;"
      edge="1" source="w_group" target="logdb" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════
         BOOK NOTES
    ═══════════════════════════════════════════ -->
    <mxCell id="note1" value="📌 Book Key Points&#xa;─────────────────────────────&#xa;• Each notification type has its own queue → no single point of failure&#xa;• Workers are stateless → easy to scale horizontally&#xa;• Retry with exponential backoff on 3rd-party failure&#xa;• Dedup: check notification log before sending (idempotency key)&#xa;• Rate limit per user to avoid spamming&#xa;• User opt-out settings respected before enqueue"
      style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;fontSize=11;rounded=1;verticalAlign=top;"
      vertex="1" parent="1">
      <mxGeometry x="40" y="500" width="220" height="160" as="geometry" />
    </mxCell>

    <mxCell id="note2" value="📌 Notification Types (book)&#xa;─────────────────────────────&#xa;• Mobile push  → APNs (iOS), FCM (Android)&#xa;• SMS          → Twilio / Nexmo&#xa;• Email        → SendGrid / Mailchimp"
      style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;fontSize=11;rounded=1;verticalAlign=top;"
      vertex="1" parent="1">
      <mxGeometry x="40" y="680" width="220" height="100" as="geometry" />
    </mxCell>

  </root>
</mxGraphModel>
