<?xml version="1.0" encoding="UTF-8"?>
<mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />

    <!-- TITLE -->
    <mxCell id="title" value="URL Shortener — System Design (Alex Xu, System Design Interview)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=16;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="200" y="20" width="760" height="30" as="geometry" />
    </mxCell>

    <!-- ── FLOW 1 LABEL ── -->
    <mxCell id="f1label" value="① Write Flow  (POST /api/v1/data/shorten)" style="text;html=1;strokeColor=none;fillColor=#dae8fc;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="60" y="65" width="380" height="25" as="geometry" />
    </mxCell>

    <!-- ── FLOW 2 LABEL ── -->
    <mxCell id="f2label" value="② Read Flow  (GET /api/v1/{shortUrl})" style="text;html=1;strokeColor=none;fillColor=#d5e8d4;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="60" y="95" width="380" height="25" as="geometry" />
    </mxCell>

    <!-- ════════════════════════════════════
         ROW 1 — CLIENT
    ════════════════════════════════════ -->
    <mxCell id="client" value="Client / Browser" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="480" y="130" width="200" height="60" as="geometry" />
    </mxCell>

    <!-- ════════════════════════════════════
         ROW 2 — RATE LIMITER
    ════════════════════════════════════ -->
    <mxCell id="rl" value="Rate Limiter&#xa;(blocks abusive IPs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="480" y="250" width="200" height="60" as="geometry" />
    </mxCell>

    <!-- ════════════════════════════════════
         ROW 3 — LOAD BALANCER
    ════════════════════════════════════ -->
    <mxCell id="lb" value="Load Balancer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="480" y="370" width="200" height="60" as="geometry" />
    </mxCell>

    <!-- ════════════════════════════════════
         ROW 4 — WEB SERVERS (stateless)
    ════════════════════════════════════ -->
    <mxCell id="ws_group" value="Web Servers (Stateless)" style="swimlane;startSize=28;fillColor=#f5f5f5;strokeColor=#666;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="310" y="490" width="540" height="90" as="geometry" />
    </mxCell>
    <mxCell id="ws1" value="Web Server 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="ws_group">
      <mxGeometry x="40" y="35" width="160" height="40" as="geometry" />
    </mxCell>
    <mxCell id="ws2" value="Web Server 2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="ws_group">
      <mxGeometry x="340" y="35" width="160" height="40" as="geometry" />
    </mxCell>

    <!-- ════════════════════════════════════
         ROW 5 — CACHE + ID GEN + BASE62
    ════════════════════════════════════ -->
    <mxCell id="cache" value="Cache (Redis)&#xa;shortURL → longURL&#xa;HIT: return | MISS: go to DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="100" y="650" width="200" height="70" as="geometry" />
    </mxCell>

    <mxCell id="idgen" value="Unique ID Generator&#xa;(Snowflake)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="480" y="650" width="200" height="70" as="geometry" />
    </mxCell>

    <mxCell id="base62" value="Base62 Encoder&#xa;ID → 7-char short code&#xa;[0-9 a-z A-Z]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="480" y="780" width="200" height="70" as="geometry" />
    </mxCell>

    <!-- ════════════════════════════════════
         ROW 6 — DATABASE
    ════════════════════════════════════ -->
    <mxCell id="db" value="Relational DB&#xa;id | shortURL | longURL" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="100" y="790" width="200" height="80" as="geometry" />
    </mxCell>

    <!-- ════════════════════════════════════
         EDGES
    ════════════════════════════════════ -->

    <!-- Client → Rate Limiter -->
    <mxCell id="e1" value="POST longURL / GET shortURL" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="client" target="rl" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Rate Limiter → Load Balancer -->
    <mxCell id="e2" value="allowed" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#82b366;" edge="1" source="rl" target="lb" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Load Balancer → Web Servers -->
    <mxCell id="e3" value="route" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="lb" target="ws_group" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Web Servers → Cache (read) -->
    <mxCell id="e4" value="1. lookup shortURL" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#d6b656;" edge="1" source="ws_group" target="cache" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Cache MISS → DB -->
    <mxCell id="e5" value="MISS → fetch" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#6c8ebf;" edge="1" source="cache" target="db" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Web Servers → ID Generator (write flow) -->
    <mxCell id="e6" value="2. generate ID" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#9673a6;" edge="1" source="ws_group" target="idgen" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ID Generator → Base62 -->
    <mxCell id="e7" value="unique ID" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#9673a6;" edge="1" source="idgen" target="base62" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Base62 → DB (store mapping) -->
    <mxCell id="e8" value="3. store shortURL→longURL" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#6c8ebf;" edge="1" source="base62" target="db" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Web Servers → Client (redirect) -->
    <mxCell id="e9" value="301 / 302 Redirect" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#b85450;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="ws_group" target="client" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="900" y="535" />
          <mxPoint x="900" y="160" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- ════════════════════════════════════
         NOTES / ANNOTATIONS
    ════════════════════════════════════ -->
    <mxCell id="note301" value="301 = Permanent (less load, no analytics)&#xa;302 = Temporary (tracks every click)" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=left;fontSize=10;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="730" y="130" width="280" height="45" as="geometry" />
    </mxCell>

    <mxCell id="notecache" value="Cache absorbs ~80% reads&#xa;(reads &gt;&gt; writes at 10:1 ratio)" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;fontSize=10;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="730" y="650" width="220" height="40" as="geometry" />
    </mxCell>

    <mxCell id="notebase62" value="7 chars = 62^7 ≈ 3.5 trillion URLs" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;fontSize=10;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="730" y="790" width="220" height="30" as="geometry" />
    </mxCell>

  </root>
</mxGraphModel>
